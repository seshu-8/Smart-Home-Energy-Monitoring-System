{
  "version": 1,
  "author": "Smart Home Energy Monitor",
  "editor": "wokwi",
  "parts": [
    {
      "type": "wokwi-esp32-devkit-v1",
      "id": "esp",
      "top": 200,
      "left": 300,
      "attrs": {}
    },
    {
      "type": "wokwi-ssd1306",
      "id": "oled1",
      "top": 0,
      "left": 300,
      "attrs": { "i2cAddress": "0x3c" }
    },
    {
      "type": "wokwi-potentiometer",
      "id": "pot1",
      "top": 0,
      "left": 550,
      "attrs": { "label": "CURRENT" }
    },
    {
      "type": "wokwi-potentiometer",
      "id": "pot2",
      "top": 0,
      "left": 700,
      "attrs": { "label": "VOLTAGE" }
    },
    {
      "type": "wokwi-led",
      "id": "led_red",
      "top": 560,
      "left": 300,
      "attrs": { "color": "red", "label": "ALERT" }
    },
    {
      "type": "wokwi-led",
      "id": "led_green",
      "top": 560,
      "left": 370,
      "attrs": { "color": "green", "label": "NORMAL" }
    },
    {
      "type": "wokwi-buzzer",
      "id": "buzzer1",
      "top": 560,
      "left": 450,
      "attrs": { "volume": "0.5" }
    },
    {
      "type": "wokwi-pushbutton",
      "id": "btn_reset",
      "top": 560,
      "left": 560,
      "attrs": { "color": "blue", "label": "RESET" }
    },
    {
      "type": "wokwi-resistor",
      "id": "r_red",
      "top": 510,
      "left": 300,
      "attrs": { "value": "330" }
    },
    {
      "type": "wokwi-resistor",
      "id": "r_green",
      "top": 510,
      "left": 370,
      "attrs": { "value": "330" }
    }
  ],
  "connections": [
    ["esp:3V3",    "oled1:VCC", "red",    []],
    ["esp:GND.1",  "oled1:GND", "black",  []],
    ["esp:D21",    "oled1:SDA", "blue",   []],
    ["esp:D22",    "oled1:SCL", "yellow", []],

    ["esp:3V3",    "pot1:VCC",  "red",    []],
    ["esp:GND.2",  "pot1:GND",  "black",  []],
    ["esp:D34",    "pot1:SIG",  "orange", []],

    ["esp:3V3",    "pot2:VCC",  "red",    []],
    ["esp:GND.2",  "pot2:GND",  "black",  []],
    ["esp:D35",    "pot2:SIG",  "purple", []],

    ["esp:D27",    "r_red:1",   "red",    []],
    ["r_red:2",    "led_red:A", "red",    []],
    ["led_red:C",  "esp:GND.2", "black",  []],

    ["esp:D25",    "r_green:1",   "green", []],
    ["r_green:2",  "led_green:A", "green", []],
    ["led_green:C","esp:GND.2",   "black", []],

    ["esp:D26",    "buzzer1:1",   "cyan",  []],
    ["buzzer1:2",  "esp:GND.2",   "black", []],

    ["esp:D33",    "btn_reset:1.l", "white", []],
    ["btn_reset:2.l", "esp:GND.2", "black", []]
  ],
  "dependencies": {}
}
